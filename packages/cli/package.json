{
  "name": "@wyw-in-js/cli",
  "version": "2.1.3",
  "type": "module",
  "bin": {
    "wyw-in-js": "bin/wyw-in-js.js"
  },
  "dependencies": {
    "@wyw-in-js/shared": "workspace:*",
    "@wyw-in-js/transform": "workspace:*",
    "glob": "^10.3.10",
    "mkdirp": "^0.5.1",
    "normalize-path": "^3.0.0",
    "yargs": "^17.5.0"
  },
  "devDependencies": {
    "@types/mkdirp": "^0.5.2",
    "@types/normalize-path": "^3.0.0",
    "@types/yargs": "^17.0.10",
    "@wyw-in-js/eslint-config": "workspace:*",
    "@wyw-in-js/ts-config": "workspace:*"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "types": "./types/wyw-in-js.d.ts",
      "default": "./esm/wyw-in-js.js"
    }
  },
  "files": [
    "bin/",
    "esm/",
    "types/"
  ],
  "license": "MIT",
  "main": "esm/wyw-in-js.js",
  "module": "esm/wyw-in-js.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:esm": "node ../../scripts/build-esm-oxc.mjs",
    "build:types": "tsc --project ./tsconfig.lib.json --baseUrl . --rootDir ./src",
    "lint": "eslint --ext .js,.ts .",
    "test": "bun test src"
  },
  "types": "types/wyw-in-js.d.ts"
