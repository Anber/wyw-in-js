{
  "name": "@wyw-in-js/esbuild",
  "version": "2.2.0",
  "type": "module",
  "dependencies": {
    "@wyw-in-js/shared": "workspace:*",
    "@wyw-in-js/transform": "workspace:*",
    "oxc-transform": "^0.131.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@wyw-in-js/eslint-config": "workspace:*",
    "@wyw-in-js/ts-config": "workspace:*",
    "esbuild": "^0.15.16"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./esm/index.mjs"
    }
  },
  "files": [
    "esm/",
    "types/"
  ],
  "license": "MIT",
  "main": "esm/index.mjs",
  "module": "esm/index.mjs",
  "peerDependencies": {
    "esbuild": ">=0.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:esm": "node ../../scripts/build-esm-oxc.mjs --out-file-extension .mjs",
    "build:types": "tsc --project ./tsconfig.lib.json --baseUrl . --rootDir ./src",
    "lint": "eslint --ext .js,.ts .",
    "test": "bun test src"
  },
  "types": "types/index.d.ts"
}
